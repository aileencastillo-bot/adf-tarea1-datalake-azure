{
	"name": "df_ventas_online_bronce_silver",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_online_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_sc_limpia__csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "filter1"
				},
				{
					"name": "derivedColumn5"
				}
			],
			"scriptLines": [
				"source(output(",
				"          order_id as string,",
				"          timestamp as string,",
				"          product as string,",
				"          qty as string,",
				"          unit_price as string,",
				"          {customer/name} as string,",
				"          {customer/email} as string,",
				"          {customer/city} as string,",
				"          payment_method as string,",
				"          status as string,",
				"          shipping_cost as string,",
				"          channel as string,",
				"          customer as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(order_id = trim(order_id),",
				"          timestamp = trim(timestamp),",
				"          product = trim(product),",
				"          qty = trim(qty),",
				"          unit_price = trim(unit_price),",
				"          payment_method = trim(payment_method),",
				"          status = trim(status),",
				"          shipping_cost = trim(shipping_cost),",
				"          channel = trim(channel),",
				"          customer = trim(customer)) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          id_orden = order_id,",
				"          fecha = timestamp,",
				"          producto = product,",
				"          cantidad = qty,",
				"          precio_unitaroo = unit_price,",
				"          nombre_cliente = {customer/name},",
				"          cliente_email = {customer/email},",
				"          ciudad_cliente = {customer/city},",
				"          metodo_pago = payment_method,",
				"          estado = status,",
				"          costo = shipping_cost,",
				"          canal = channel,",
				"          cliente = customer",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(producto = initCap(regexReplace(producto,'\\\\s+',' '))) ~> derivedColumn2",
				"derivedColumn2 derive(precio_unitaroo = toFloat(regexReplace(toString(precio_unitaroo), '[^0-9.]', '')),",
				"          cantidad = toInteger(cantidad)) ~> derivedColumn3",
				"derivedColumn3 derive(fecha = coalesce(    toDate(replace(fecha, ' de ', ' '), 'dd MMMM yyyy', 'en-US'),    toDate(fecha, 'MMMM dd, yyyy', 'en-US'),    toDate(fecha, 'yyyy-MM-dd'),     toDate(fecha, 'dd-MM-yyyy'),     toDate(fecha, 'MM-dd-yyyy'),     toDate(fecha, 'dd/MM/yyyy'),     toDate(fecha, 'yyyy/MM/dd'),    toDate(fecha, 'dd/MMM/yyyy'),    toDate(fecha, 'dd-MMM-yyyy'))) ~> derivedColumn4",
				"derivedColumn4 filter(cantidad > 0 && !isNull(precio_unitaroo) && !isNull(fecha)) ~> filter1",
				"filter1 derive(canal = 'sucursal') ~> derivedColumn5",
				"derivedColumn5 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['ventas_online_limpio_csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}